# ---------- App ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database (Prisma) ----------
# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/client_reporting?schema=public"
# Direct (non-pooled) URL — needed for Prisma Migrate when using a pooler like PgBouncer/Neon
DIRECT_URL="postgresql://user:password@localhost:5432/client_reporting?schema=public"

# ---------- NextAuth ----------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# OAuth providers (fill the ones you use)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe price IDs for plans
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...

# ---------- Email (Resend) ----------
RESEND_API_KEY=re_...
EMAIL_FROM="Client Reporting <noreply@example.com>"
