# ---------- App ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database (Prisma) ----------
# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/client_reporting?schema=public"
# Direct (non-pooled) URL — needed for Prisma Migrate when using a pooler like PgBouncer/Neon
DIRECT_URL="postgresql://user:password@localhost:5432/client_reporting?schema=public"

# ---------- NextAuth ----------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# OAuth providers (fill the ones you use)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe price IDs for plans
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...

# ---------- Email (SMTP for magic-link sign-in) ----------
# Gmail example: enable 2FA, then create an App Password
# (Google Account → Security → 2-Step Verification → App passwords).
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=you@gmail.com
EMAIL_SERVER_PASSWORD=your-16-char-app-password
EMAIL_FROM="Client Reporting <you@gmail.com>"

# ---------- Resend (only used for report delivery, not sign-in) ----------
RESEND_API_KEY=re_...
