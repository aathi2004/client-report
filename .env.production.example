# =============================================================================
# Production environment variables for Client Reporting Engine
# Copy these into Vercel → Project → Settings → Environment Variables
# (or `vercel env add` for each). Do NOT commit the filled file.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Use the connection-pooled URL (port 6543) for runtime queries on serverless.
# Find it in Supabase → Project Settings → Database → Connection string → "Transaction".
# URL-encode any special characters in the password (e.g. @ → %40).
DATABASE_URL="postgresql://postgres:<password>@<ref>.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Optional but recommended for `prisma migrate deploy` from CI: the direct (port 5432) URL.
DIRECT_URL="postgresql://postgres:<password>@<ref>.supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# Public URL of your production deployment (no trailing slash).
NEXTAUTH_URL="https://your-domain.com"

# 32+ random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""

# -----------------------------------------------------------------------------
# Google OAuth (for sign-in via Google) — optional if you only use magic link
# -----------------------------------------------------------------------------
# Authorized redirect URI to register: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Production: verify a domain at https://resend.com/domains, then use a sender
# on that domain (e.g. reports@your-domain.com). The sandbox 'onboarding@resend.dev'
# only delivers to the Resend account owner.
RESEND_API_KEY=""
EMAIL_FROM="reports@your-domain.com"

# -----------------------------------------------------------------------------
# Stripe — LIVE mode keys for production
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/apikeys (toggle "Test mode" OFF first)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."

# Live-mode price IDs created in https://dashboard.stripe.com/products
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# Webhook signing secret. Create the endpoint at:
# https://dashboard.stripe.com/webhooks → Add endpoint
#   URL:    https://your-domain.com/api/stripe/webhook
#   Events: checkout.session.completed, customer.subscription.updated,
#           customer.subscription.deleted, invoice.payment_failed
# Then copy the signing secret here.
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Supabase Storage (for client logos and report PDFs)
# -----------------------------------------------------------------------------
# Project URL: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"

# Service-role key (KEEP SECRET — bypasses RLS).
# Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=""

# Required buckets (create in Supabase Storage with Public = ON):
#   - client-logos   (allowed: image/jpeg, image/png, image/webp; size: 20 MB)
#   - reports        (allowed: application/pdf; size: 20 MB)

# -----------------------------------------------------------------------------
# Google Ads OAuth + API
# -----------------------------------------------------------------------------
# OAuth Web client. Register redirect URI:
#   https://your-domain.com/api/sources/google-ads/callback
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""

# Developer token from https://ads.google.com/aw/apicenter (requires MCC).
# Test accounts work without approval.
GOOGLE_ADS_DEVELOPER_TOKEN=""

# Optional: digit-only customer ID used as fallback when DataSource.accountId is null.
GOOGLE_ADS_CUSTOMER_ID=""

# Optional: manager (MCC) customer ID if your OAuth was authorized via manager.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""

# -----------------------------------------------------------------------------
# Encryption — for OAuth tokens stored in DataSource.credentials (AES-256-GCM)
# -----------------------------------------------------------------------------
# 32 bytes hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_SOURCE_ENCRYPTION_KEY=""

# -----------------------------------------------------------------------------
# Cron — used by /api/cron/send-scheduled
# -----------------------------------------------------------------------------
# When set, Vercel Cron automatically sends Authorization: Bearer ${CRON_SECRET}.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=""
